{
    "name": "nano-code-devcontainer",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "workspaceFolder": "/nano-code",
    "remoteUser": "vscode",
    "mounts": ["source=${localWorkspaceFolder},target=/nano-code,type=bind"],
    "runArgs": ["--add-host=host.docker.internal:host-gateway"],
    "customizations": {
        "vscode": {
            "extensions": ["esbenp.prettier-vscode", "anthropic.claude-code"]
        }
    },
    "postCreateCommand": "if [ ! -f package.json ]; then bun init -y; fi && bun install || true"
}
