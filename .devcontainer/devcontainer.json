{
  "name": "nano-code-devcontainer",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/nano-code",
  "remoteUser": "vscode",
  "mounts": ["source=${localWorkspaceFolder},target=/nano-code,type=bind"],
  "forwardPorts": [18000],
  "portsAttributes": {
    "18000": {
      "label": "ollama-tunnel",
      "onAutoForward": "silent"
    }
  },
  "runArgs": ["--add-host=host.docker.internal:host-gateway"],
  "containerEnv": {
    "LLM_PROVIDER": "openai",
    "LLM_MODEL": "gpt-oss:20b"
  },
  "customizations": {
    "vscode": {
      "extensions": ["esbenp.prettier-vscode", "anthropic.claude-code"]
    }
  },
  "postCreateCommand": "bun install || true"
}
